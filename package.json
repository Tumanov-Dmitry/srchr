  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test:notifications": "node --test tests/notifications/*.test.mjs",
    "test:reputation": "node --test tests/reputation/*.test.mjs",
